generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  OPEN
  BUSY
  CLOSED
}

enum BookingStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

enum SlotStatus {
  AVAILABLE
  FULL
  CLOSED
}

enum QueueEventType {
  TOKEN_ADVANCED
  STATUS_UPDATED
  QUEUE_LENGTH_CHANGED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  fullName     String    @map("full_name")
  passwordHash String    @map("password_hash")
  roleId       Int       @default(2) @map("role_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  bookings     Booking[]

  @@map("users")
}

model Service {
  id                 String               @id @default(uuid())
  name               String
  description        String
  location           String
  avgServiceTime     Int                  @map("avg_service_time")
  currentQueueLength Int                  @default(0) @map("current_queue_length")
  currentToken       Int                  @default(0) @map("current_token")
  status             ServiceStatus        @default(OPEN)
  slotDuration       Int                  @default(15) @map("slot_duration")
  slotCapacity       Int                  @default(5) @map("slot_capacity")
  openingTime        String               @map("opening_time")
  closingTime        String               @map("closing_time")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  slots              Slot[]
  bookings           Booking[]
  queueLogs          QueueLog[]
  serviceTimeHistory ServiceTimeHistory[]

  @@map("services")
}

model Slot {
  id        String     @id @default(uuid())
  serviceId String     @map("service_id")
  startTime DateTime   @map("start_time")
  endTime   DateTime   @map("end_time")
  capacity  Int
  booked    Int        @default(0)
  status    SlotStatus @default(AVAILABLE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@map("slots")
}

model Booking {
  id                String        @id @default(uuid())
  userId            String        @map("user_id")
  serviceId         String        @map("service_id")
  slotId            String        @map("slot_id")
  bookingToken      Int           @map("booking_token")
  status            BookingStatus @default(BOOKED)
  estimatedWaitTime Int           @map("estimated_wait_time")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  service           Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  slot              Slot          @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model QueueLog {
  id           String         @id @default(uuid())
  serviceId    String         @map("service_id")
  eventType    QueueEventType @map("event_type")
  queueLength  Int            @map("queue_length")
  currentToken Int            @map("current_token")
  note         String?
  createdAt    DateTime       @default(now()) @map("created_at")
  service      Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("queue_logs")
}

model ServiceTimeHistory {
  id             String   @id @default(uuid())
  serviceId      String   @map("service_id")
  servedAt       DateTime @default(now()) @map("served_at")
  actualDuration Int      @map("actual_duration")
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_time_history")
}
